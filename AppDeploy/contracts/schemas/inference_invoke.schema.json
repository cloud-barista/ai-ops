{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KHU Inference Invoke Request",
  "type": "object",
  "properties": {
    "method": {
      "enum": [
        "GET",
        "POST"
      ]
    },
    "path": {
      "type": "string",
      "pattern": "^/[^\\r\\n\\t]*$"
    },
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 300
    },
    "headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "body": true
  }
}
