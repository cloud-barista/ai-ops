{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KHU Inference Metric",
  "type": "object",
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "latency_ms": {
      "type": "number",
      "minimum": 0
    },
    "throughput_rps": {
      "type": "number",
      "minimum": 0
    },
    "quality_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "request_count": {
      "type": "integer",
      "minimum": 0
    },
    "error_count": {
      "type": "integer",
      "minimum": 0
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
