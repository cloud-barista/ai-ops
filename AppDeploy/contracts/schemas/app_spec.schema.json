{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KHU AI App Spec",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "metadata",
    "artifact",
    "entrypoint",
    "runtime",
    "resources"
  ],
  "properties": {
    "schema_version": {
      "const": "appspec.khu.ai/v1alpha1"
    },
    "kind": {
      "const": "AIApp"
    },
    "metadata": {
      "type": "object",
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,62}$"
        },
        "version": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "artifact": {
      "type": "object",
      "required": [
        "type",
        "uri"
      ],
      "properties": {
        "type": {
          "enum": [
            "package",
            "git",
            "binary",
            "script"
          ]
        },
        "uri": {
          "type": "string"
        },
        "checksum": {
          "type": "string"
        }
      },
      "not": {
        "properties": {
          "type": {
            "const": "container"
          }
        }
      }
    },
    "entrypoint": {
      "type": "object",
      "required": [
        "command"
      ],
      "properties": {
        "command": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "working_dir": {
          "type": "string"
        }
      }
    },
    "runtime": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "cpu",
            "gpu",
            "aiinfra",
            "mock"
          ]
        },
        "accelerator": {
          "enum": [
            "none",
            "nvidia"
          ]
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "cpu": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        },
        "gpu": {
          "type": "string"
        },
        "storage": {
          "type": "string"
        }
      }
    },
    "model_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "uri"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "uri": {
            "type": "string"
          },
          "mount_path": {
            "type": "string"
          }
        }
      }
    },
    "network": {
      "type": "object",
      "properties": {
        "ports": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "app_port"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "app_port": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              },
              "protocol": {
                "enum": [
                  "TCP",
                  "UDP"
                ]
              }
            }
          }
        }
      }
    },
    "healthcheck": {
      "type": "object",
      "properties": {
        "type": {
          "enum": [
            "http",
            "command"
          ]
        },
        "path": {
          "type": "string"
        },
        "command": {
          "type": "string"
        }
      }
    }
  }
}