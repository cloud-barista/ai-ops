{
  "app_spec": {
    "schema_version": "appspec.khu.ai/v1alpha1",
    "kind": "AIApp",
    "metadata": {
      "name": "tiny-classifier",
      "version": "0.1.0",
      "description": "Tiny CPU AI classifier served over HTTP for real VM deployment smoke tests"
    },
    "artifact": {
      "type": "script",
      "uri": "file:///C:/Users/User/Desktop/AI-MCMP/app_deploy/examples/apps/tiny-classifier/run.sh"
    },
    "entrypoint": {
      "command": "bash",
      "args": [
        "run.sh",
        "--port=18080"
      ]
    },
    "runtime": {
      "type": "cpu",
      "accelerator": "none"
    },
    "resources": {
      "cpu": "1",
      "memory": "512Mi",
      "gpu": "0",
      "storage": "1Gi"
    },
    "network": {
      "ports": [
        {
          "name": "http",
          "app_port": 18080,
          "protocol": "TCP"
        }
      ]
    },
    "healthcheck": {
      "type": "http",
      "path": "/health"
    }
  }
}
