{
  "app_spec": {
    "schema_version": "appspec.khu.ai/v1alpha1",
    "kind": "AIApp",
    "metadata": {
      "name": "sample-gpu-app",
      "version": "0.1.0",
      "description": "GPU VM smoke app"
    },
    "artifact": {
      "type": "script",
      "uri": "file:///opt/examples/sample-gpu-app/run.sh"
    },
    "entrypoint": {
      "command": "bash",
      "args": [
        "run.sh",
        "--port=18081"
      ]
    },
    "runtime": {
      "type": "gpu",
      "accelerator": "nvidia"
    },
    "resources": {
      "cpu": "4",
      "memory": "16Gi",
      "gpu": "1",
      "storage": "20Gi"
    },
    "network": {
      "ports": [
        {
          "name": "http",
          "app_port": 18081,
          "protocol": "TCP"
        }
      ]
    },
    "healthcheck": {
      "type": "http",
      "path": "/health"
    }
  }
}
